{
  "name": "office-to-markdown",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "generate:smoke-fixtures": "if [ ! -d .venv ]; then python3 -m venv .venv; fi && . .venv/bin/activate && python -m pip install --quiet -r requirements.txt && python scripts/generate_smoke_fixtures.py",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:browser": "playwright test",
    "test": "./scripts/run-python-tests.sh",
    "quality": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "packageManager": "pnpm@8.15.6",
  "dependencies": {
    "@uploadthing/react": "^7.3.3",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uploadthing": "^7.7.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.2.0",
    "typescript": "^5.7.3"
  }
}
